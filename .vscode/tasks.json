{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pnpm-install",
      "type": "shell",
      "command": "pnpm install --dangerously-allow-all-builds",
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    }
  ]
}